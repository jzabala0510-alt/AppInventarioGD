PORT=8085
# El frontend llama a /Reposiciones/recursos/... (nombre del .war original + el
# @ApplicationPath("recursos") de JAX-RS) -- mantener este prefijo completo para
# no tener que tocar ninguna URL del frontend existente.
BASE_PATH=/Reposiciones/recursos

DB_HOST=
DB_PORT=1433
DB_INSTANCE=MSSQLSERVER
DB_NAME=
DB_USER=
DB_PASSWORD=

# Base64 del secreto de firma JWT. Si se necesita compatibilidad con tokens ya
# emitidos por el backend Java actual, usar el mismo valor que Reposiciones.war.
JWT_SECRET_BASE64=
JWT_EXPIRES_IN=8h
